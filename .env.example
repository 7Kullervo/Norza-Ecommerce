# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS + Stripe redirect URLs) - your GitHub Pages site
CLIENT_URL=https://7kullervo.github.io/Norza-Ecommerce

# MongoDB
# Local:   mongodb://127.0.0.1:27017/norza
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/norza
MONGO_URI=mongodb://127.0.0.1:27017/norza

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# First admin account (created automatically by the seed script if it doesn't exist)
ADMIN_EMAIL=admin@norza.com
ADMIN_PASSWORD=ChangeMe123!
